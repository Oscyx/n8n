      "parameters": {
        "jsCode": "const binaryProp = $input.first().binary;\nlet rawBuffer;\n\nif (binaryProp && binaryProp.data) {\n  rawBuffer = Buffer.from(binaryProp.data);\n} else if (binaryProp && Object.keys(binaryProp).length > 0) {\n  const firstKey = Object.keys(binaryProp)[0];\n  rawBuffer = Buffer.from(binaryProp[firstKey].data);\n} else {\n  const text = $input.first().json.output || $input.first().json.data || '';\n  const items = parseRSS(text, 'utf-8');\n  return items.map(item => ({ json: { ...item, _encoding: 'utf-8 (fallback)' } }));\n}\n\nfunction parseRSS(content) {\n  const items = [];\n  const itemRegex = /<(?:item|entry)[^>]*>([\\s\\S]*?)<\\/(?:item|entry)>/gi;\n  let match;\n  while ((match = itemRegex.exec(content)) !== null && items.length < 50) {\n    const itemXml = match[1];\n    const getTag = (tag) => {\n      const re = new RegExp('<' + tag + '[^>]*><!\\\\[CDATA\\\\[([\\\\s\\\\S]*?)\\\\]\\\\]><\\\\/' + tag + '>|<' + tag + '[^>]*>([\\\\s\\\\S]*?)<\\\\/' + tag + '>', 'gi');\n      const m = itemXml.match(re);\n      return m ? (m[1] || m[2] || '').trim() : '';\n    };\n    const title = getTag('title');\n    const link = getTag('link');\n    const description = getTag('description') || getTag('summary') || getTag('content');\n    const pubDate = getTag('pubDate') || getTag('published') || getTag('updated') || '';\n    const cleanDesc = (description || '').replace(/<[^>]+>/g, '').substring(0, 800);\n    if (title || link) {\n      items.push({\n        title: title || '',\n        link,\n        guid: getTag('guid') || link,\n        description: cleanDesc,\n        pubDate: pubDate.substring(0, 10),\n        published_raw: pubDate\n      });\n    }\n  }\n  return items;\n}\n\nconst sample = rawBuffer.toString('ascii', 0, 200);\nlet encoding = 'utf-8';\nconst encMatch = sample.match(/encoding=[\"']([^\"']+)[\"']/i);\nif (encMatch) {\n  const e = encMatch[1].toLowerCase();\n  if (e === 'gbk' || e === 'gb2312' || e === 'gb18030') encoding = 'gbk';\n}\n\nconst content = rawBuffer.toString(encoding);\nconst items = parseRSS(content);\nreturn items.map(item => ({ json: { ...item, _encoding: encoding } }));"
