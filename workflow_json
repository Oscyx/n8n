        "jsCode": "const items = $input.all();\nif (!items || items.length === 0) {\n  return { json: { html: '<p>今日无新数据</p>', count: 0, categories: {} } };\n}\n\nconst categories = {};\nitems.forEach(item => {\n  const cat = item.json.category || '其他';\n  categories[cat] = (categories[cat] || 0) + 1;\n});\n\nconst rows = items.map((item, idx) => {\n  const d = item.json;\n  const hot = d.isHot === '是' || d.is_hot === '是' ? '🔥' : '';\n  return `<tr>\n    <td>${idx + 1}</td>\n    <td>${d.category || d.pub_date || '其他'}</td>\n    <td><a href=\"${d.link || '#'}\">${(d.title || '').substring(0, 50)}</a></td>\n    <td>${d.source || ''}</td>\n    <td>${d.pub_date || ''}</td>\n    <td>${hot}${d.summary || ''}</td>\n  </tr>`;\n}).join('\\n');\n\nconst catSummary = Object.entries(categories).map(([cat, cnt]) => `<li><strong>${cat}</strong>: ${cnt} 条</li>`).join('');\n\nconst html = `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>家电资讯日报</title>\n  <style>\n    body { font-family: Arial, sans-serif; margin: 20px; }\n    h1 { color: #333; }\n    table { border-collapse: collapse; width: 100%; margin-top: 20px; }\n    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; font-size: 13px; }\n    th { background-color: #4A90D9; color: white; }\n    tr:nth-child(even) { background-color: #f9f9f9; }\n    tr:hover { background-color: #f1f1f1; }\n    .summary { background: #f0f7ff; padding: 15px; border-radius: 8px; margin-bottom: 20px; }\n    .summary h3 { margin-top: 0; }\n    .cat-list { overflow: hidden; }\n    .cat-list li { float: left; margin-right: 20px; }\n  </style>\n</head>\n<body>\n  <h1>家电资讯日报</h1>\n  <p>生成时间：${new Date().toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' })}</p>\n  <div class=\"summary\">\n    <h3>今日概况</h3>\n    <p><strong>总计：</strong>${items.length} 条 | <strong>热点：</strong>${items.filter(i => i.json.isHot === '是' || i.json.is_hot === '是').length} 条</p>\n    <p><strong>品类分布：</strong></p>\n    <ul class=\"cat-list\">${catSummary}</ul>\n  </div>\n  <table>\n    <thead>\n      <tr><th>#</th><th>品类</th><th>标题</th><th>来源</th><th>日期</th><th>摘要</th></tr>\n    </thead>\n    <tbody>${rows}</tbody>\n  </table>\n</body>\n</html>`;\n\nreturn { json: { html, count: items.length, categories } };"
