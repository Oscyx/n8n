ption: '', source: sourceName });\n    }\n  });\n}\n\n// leikeji.com: href=\"https://www.leikeji.com/article/\\d+\"  (标题需要抓详情页获取)\nconst lkjMatches = content.match(/href=\"(https:\\/\\/www\\.leikeji\\.com\\/article\\/\\d+)\"[^>]*>/gi);\nif (lkjMatches) {\n  lkjMatches.forEach(m => {\n    const lm = m.match(/href=\"(https:\\/\\/www\\.leikeji\\.com\\/article\\/\\d+)\"/);\n    if (lm) {\n      articles.push({ title: '', link: lm[1], guid: lm[1], pubDate: '', description: '', source: sourceName });\n    }\n  });\n}\n\nconst seen = new Set();\nconst unique = articles.filter(a => { if (seen.has(a.guid)) return false; seen.add(a.guid); return true; });\nreturn unique.slice(0, 30).map(a => ({ json: a }));"
