    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nif (!allItems || allItems.length === 0) return [];\n\nfunction similarity(a, b) {\n  const s1 = new Set(a.split(''));\n  const s2 = new Set(b.split(''));\n  const intersection = [...s1].filter(c => s2.has(c)).length;\n  const union = new Set([...s1, ...s2]).size;\n  return union > 0 ? intersection / union : 0;\n}\n\nconst skipGuids = new Set();\nfor (let i = 0; i < allItems.length; i++) {\n  if (skipGuids.has(allItems[i].json.guid)) continue;\n  for (let j = i + 1; j < allItems.length; j++) {\n    if (skipGuids.has(allItems[j].json.guid)) continue;\n    const t1 = (allItems[i].json.title || '').toLowerCase();\n    const t2 = (allItems[j].json.title || '').toLowerCase();\n    if (t1.length < 5 || t2.length < 5) continue;\n    if (similarity(t1, t2) > 0.75) {\n      const cat1 = allItems[i].json.category || '';\n      const cat2 = allItems[j].json.category || '';\n      if (cat1 === cat2 || cat1 === '其他' || cat2 === '其他') {\n        skipGuids.add(allItems[j].json.guid);\n      }\n    }\n  }\n}\n\nreturn allItems\n  .filter(item => !skipGuids.has(item.json.guid))\n  .map(item => ({ json: { ...item.json, skipDuplicate: skipGuids.has(item.json.guid) } }));"
      },
